<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Package visibility (Android 11+, API 30+): without this,
         queryIntentActivities() for a `geo:` intent silently returns
         nothing for any app outside this one, even when a real nav app
         (Google Maps, Waze) is genuinely installed - found via real-device
         testing, NavAppPreference.kt's picker showed only the built-in
         option even with Google Maps confirmed installed and resolvable
         via `adb shell cmd package resolve-activity`, which isn't subject
         to this restriction the way the app's own process is. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="geo" />
        </intent>
    </queries>

    <!-- Reachability probe + always-needed -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />

    <!-- Blue-dot + route-from-here on the dashboard's embedded Navigate map
         (dashboard/NavigateMapFragment). Coarse is enough for the map's
         LocationComponent; fine gives a tighter starting point for routing. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- Screen capture pipeline (ARCHITECTURE.md §2) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Audio capture (ARCHITECTURE.md §3). RECORD_AUDIO is required even for
         AudioPlaybackCapture on API 29+, not just for the mic. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- Input injection, free tier default (Foundation §6b item 2) -->
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE"
        tools:ignore="ProtectedPermissions" />

    <!-- Reachability tiers (b)/(c) (ARCHITECTURE.md §7). Declared now even though
         VpnService isn't implemented yet (S1_reachability.md), so the manifest
         doesn't need touching again when it lands. -->
    <uses-permission android:name="android.permission.BIND_VPN_SERVICE"
        tools:ignore="ProtectedPermissions" />

    <!-- Phone tile: recent calls + contacts w/ A-Z scrubber
         (dashboard/PhoneOverlayView.kt). Runtime dangerous permissions
         (unlike accessibility/notification-listener above, which are
         special-access settings toggles) - requested via the standard
         system permission dialog, not a Settings redirect. Sideloaded, not
         Play-distributed, so Play's "default dialer/companion app only"
         READ_CALL_LOG restriction doesn't apply here. -->
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- In-app update install (update/ApkInstaller.kt): lets the app hand a
         downloaded APK straight to the system installer instead of routing
         through the browser. Still one explicit user tap on the installer's
         own confirmation, Android never skips that for a non-Play app; this
         only removes the "open Chrome, find the download notification" hop. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:name=".VehplayerApplication"
        android:allowBackup="false"
        android:label="@string/app_name"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">

        <activity
            android:name="app.vehplayer.android.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.AppCompat.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The car-facing home screen (ARCHITECTURE.md casting model:
             mirror mode shows whatever's in the foreground on the phone,
             this is what's deliberately put there once streaming starts,
             instead of MainActivity's own setup screen). Landscape-locked
             to match a car's screen; screenOrientation is enough here since
             this activity is only ever reached after the car viewport is
             already known to be landscape. -->
        <activity
            android:name="app.vehplayer.android.dashboard.CarDashboardActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.AppCompat.NoActionBar" />

        <!-- Owns MediaProjection capture (video AND audio, ARCHITECTURE.md §1/§2/§3)
             plus the WS server. Combined foregroundServiceType is deliberate:
             AudioPlaybackCaptureConfiguration needs the live MediaProjection
             object this service already holds for video, splitting audio into
             its own service would mean re-deriving or passing that object
             across a service boundary for no real benefit at this scale. -->
        <service
            android:name="app.vehplayer.android.capture.CaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection|microphone" />

        <service
            android:name="app.vehplayer.android.input.VehplayerAccessibilityService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Now Playing (real MediaSession data) + Messages (cross-app
             notification-based inbox), both on this one listener grant -
             MediaSessionManager.getActiveSessions requires an enabled
             NotificationListenerService component regardless of whether
             notification content itself is read, so one permission ask
             covers both features. See NEXT_SESSION.md. -->
        <service
            android:name="app.vehplayer.android.media.VehplayerNotificationListenerService"
            android:exported="false"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Reachability tier (c) fallback (ARCHITECTURE.md §7): assigns a
             100.64.0.0/10 (CGNAT) address via VpnService, sidestepping the
             RFC1918 block Tesla's in-car browser is confirmed to apply -
             see VpnReachabilityService.kt for the evidence this range is
             based on. -->
        <service
            android:name="app.vehplayer.android.net.VpnReachabilityService"
            android:exported="false"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <!-- Hands the downloaded update APK (app-specific external files dir,
             see ApkInstaller.kt) to the system installer as a content:// URI;
             required since Android N, file:// URIs across app boundaries are
             blocked. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>

