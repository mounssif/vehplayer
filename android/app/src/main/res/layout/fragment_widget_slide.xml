<?xml version="1.0" encoding="utf-8"?>
<!-- One pinned widget, full hero-card size (WidgetSlideFragment). -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:id="@+id/widgetSlideContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp" />

    <ImageView
        android:id="@+id/widgetSlideUnpinButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_margin="10dp"
        android:padding="9dp"
        android:background="@drawable/bg_icon_badge"
        android:src="@drawable/ic_close"
        android:contentDescription="Unpin widget"
        app:tint="@color/dash_text_primary" />

</FrameLayout>
