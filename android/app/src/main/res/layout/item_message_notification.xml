<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_suggestion_item"
    android:paddingHorizontal="4dp"
    android:paddingVertical="14dp"
    android:focusable="true"
    android:clickable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/messageSender"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/space_grotesk_medium"
            android:textColor="@color/dash_text_primary"
            android:textSize="17sp"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Jamie"
            xmlns:tools="http://schemas.android.com/tools" />

        <TextView
            android:id="@+id/messageApp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/space_grotesk_regular"
            android:textColor="@color/dash_text_muted"
            android:textSize="12sp"
            tools:text="WhatsApp"
            xmlns:tools="http://schemas.android.com/tools" />
    </LinearLayout>

    <TextView
        android:id="@+id/messageText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:fontFamily="@font/space_grotesk_regular"
        android:textColor="@color/dash_text_muted"
        android:textSize="15sp"
        android:maxLines="2"
        android:ellipsize="end"
        tools:text="Are we still on for tonight? Let me know when you're close"
        xmlns:tools="http://schemas.android.com/tools" />
</LinearLayout>
