<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_suggestion_item"
    android:paddingHorizontal="4dp"
    android:paddingVertical="16dp"
    android:focusable="true"
    android:clickable="true">

    <TextView
        android:id="@+id/navAppLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="@font/space_grotesk_medium"
        android:textColor="@color/dash_text_primary"
        android:textSize="17sp"
        tools:text="Google Maps"
        xmlns:tools="http://schemas.android.com/tools" />

    <ImageView
        android:id="@+id/navAppCheck"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_check"
        app:tint="@color/dash_accent_amber"
        android:visibility="gone" />
</LinearLayout>
