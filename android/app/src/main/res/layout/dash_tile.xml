<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_tile"
    android:paddingHorizontal="20dp"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/tileIconBadge"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_icon_badge_amber"
        android:padding="10dp"
        android:src="@drawable/ic_navigation"
        app:tint="@color/dash_accent_amber" />

    <TextView
        android:id="@+id/tileLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:fontFamily="@font/space_grotesk_medium"
        android:textColor="@color/dash_text_primary"
        android:textSize="18sp"
        android:text="Navigate" />
</LinearLayout>
