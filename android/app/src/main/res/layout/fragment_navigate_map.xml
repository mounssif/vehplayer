<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.mapbox.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Search bar: our own destination search + routing (Android has no API
         to read another app's active nav destination, see NEXT_SESSION.md). -->
    <LinearLayout
        android:id="@+id/searchBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@drawable/bg_search_bar"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_navigation"
            app:tint="@color/dash_text_muted" />

        <EditText
            android:id="@+id/destinationInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:background="@null"
            android:fontFamily="@font/space_grotesk_regular"
            android:textColor="@color/dash_text_primary"
            android:textColorHint="@color/dash_text_muted"
            android:textSize="16sp"
            android:hint="Where to?"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLines="1" />

        <ProgressBar
            android:id="@+id/searchProgress"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:visibility="gone"
            android:indeterminateTint="@color/dash_accent_amber" />
    </LinearLayout>

    <TextView
        android:id="@+id/routeInfoPill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_search_bar"
        android:fontFamily="@font/space_grotesk_medium"
        android:textColor="@color/dash_text_primary"
        android:textSize="14sp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:visibility="gone"
        tools:text="12 min &#8226; 8.4 km"
        xmlns:tools="http://schemas.android.com/tools" />

    <TextView
        android:id="@+id/searchErrorText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_search_bar"
        android:fontFamily="@font/space_grotesk_medium"
        android:textColor="@color/dash_text_muted"
        android:textSize="14sp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:visibility="gone" />
</FrameLayout>
