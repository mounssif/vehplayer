<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.mapbox.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Launcher pill only - real text entry happens in
         DestinationSearchOverlayView (full-screen, see that class), not
         inline here: this fragment's hero card is too short on-screen to
         fit a search field + suggestions + a real keyboard together. -->
    <LinearLayout
        android:id="@+id/searchBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@drawable/bg_search_bar"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_navigation"
            app:tint="@color/dash_text_muted" />

        <TextView
            android:id="@+id/destinationInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:fontFamily="@font/space_grotesk_regular"
            android:textColor="@color/dash_text_primary"
            android:textColorHint="@color/dash_text_muted"
            android:textSize="16sp"
            android:hint="Where to?"
            android:maxLines="1"
            android:ellipsize="end" />

        <ProgressBar
            android:id="@+id/searchProgress"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:visibility="gone"
            android:indeterminateTint="@color/dash_accent_amber" />
    </LinearLayout>

    <!-- Recenter-on-me: once you've panned/searched away, there was
         previously no way back to your own position short of relaunching
         the fragment. -->
    <ImageView
        android:id="@+id/recenterButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:padding="10dp"
        android:background="@drawable/bg_icon_badge"
        android:src="@drawable/ic_locate"
        app:tint="@color/dash_bg"
        android:contentDescription="Recenter on my location" />

    <!-- Choose which app destinations open in - built-in map or a real
         installed nav app (NavAppPreference.kt), per real user feedback. -->
    <ImageView
        android:id="@+id/navAppSettingsButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:padding="11dp"
        android:background="@drawable/bg_search_bar"
        android:src="@drawable/ic_settings"
        app:tint="@color/dash_text_muted"
        android:contentDescription="Choose navigation app" />

    <TextView
        android:id="@+id/routeInfoPill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_search_bar"
        android:fontFamily="@font/space_grotesk_medium"
        android:textColor="@color/dash_text_primary"
        android:textSize="14sp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:visibility="gone"
        tools:text="12 min &#8226; 8.4 km"
        xmlns:tools="http://schemas.android.com/tools" />

    <TextView
        android:id="@+id/searchErrorText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_search_bar"
        android:fontFamily="@font/space_grotesk_medium"
        android:textColor="@color/dash_text_muted"
        android:textSize="14sp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:visibility="gone" />
</FrameLayout>
