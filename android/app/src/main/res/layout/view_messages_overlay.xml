<?xml version="1.0" encoding="utf-8"?>
<!-- Full-screen recent-messages overview, same pattern and reasoning as
     view_destination_search_overlay.xml: owned at the CarDashboardActivity
     level so it gets the whole screen, not just a tile's worth of space.
     See MessagesOverlayView.kt. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dash_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/messagesCloseButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_close"
            android:contentDescription="Close messages"
            app:tint="@color/dash_text_muted" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/space_grotesk_bold"
            android:textColor="@color/dash_text_primary"
            android:textSize="20sp"
            android:text="Messages" />

        <TextView
            android:id="@+id/messagesOpenAppButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:background="@drawable/bg_search_bar"
            android:fontFamily="@font/space_grotesk_medium"
            android:textColor="@color/dash_accent_amber"
            android:textSize="14sp"
            android:text="Open app" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/messagesEmptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_message"
            android:alpha="0.35"
            app:tint="@color/dash_text_muted" />

        <TextView
            android:id="@+id/messagesEmptyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/space_grotesk_medium"
            android:textColor="@color/dash_text_muted"
            android:textSize="16sp"
            android:text="No recent messages" />

        <TextView
            android:id="@+id/messagesEmptySubtext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginHorizontal="32dp"
            android:gravity="center"
            android:fontFamily="@font/space_grotesk_regular"
            android:textColor="@color/dash_text_muted"
            android:alpha="0.7"
            android:textSize="13sp"
            android:visibility="gone" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/messagesScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/messagesList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
