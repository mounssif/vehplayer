<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dash_bg"
    android:padding="28dp">

    <TextView
        android:id="@+id/clockText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/space_grotesk_bold"
        android:textColor="@color/dash_text_primary"
        android:textSize="34sp"
        android:text="00:00"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/wordmarkText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/space_grotesk_medium"
        android:textColor="@color/dash_text_muted"
        android:textSize="15sp"
        android:letterSpacing="0.08"
        android:text="vehplayer"
        app:layout_constraintTop_toTopOf="@id/clockText"
        app:layout_constraintBottom_toBottomOf="@id/clockText"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Hero card: the single largest, most-glanced-at element, deliberately
         not a tile among equal tiles. Swipes between two pages (heroPager,
         adapter in CarDashboardActivity): Now Playing and Navigate - the
         "slide" the user asked for, each page a Fragment so the embedded
         MapView on the Navigate page gets correct lifecycle forwarding.
         clipToOutline rounds the pager's contents (incl. the edge-to-edge
         map) to bg_hero_card_shape's corner radius. -->
    <FrameLayout
        android:id="@+id/heroCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_hero_card_shape"
        android:clipToOutline="true"
        app:layout_constraintTop_toBottomOf="@id/clockText"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tilesColumn"
        app:layout_constraintWidth_percent="0.6"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="18dp">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/heroPager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- One dot per pager page, built dynamically (page count varies
             with pinned widgets) - see CarDashboardActivity.refreshPageDots.
             elevation keeps the strip above the pager's pages regardless of
             what a page renders (verified live: without it, some pages drew
             over the dots). -->
        <LinearLayout
            android:id="@+id/heroPageDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:elevation="4dp" />
    </FrameLayout>

    <!-- Compact tappable chip; the actual URL/hotspot/QR detail lives in the
         probeQrOverlay it opens (CarDashboardActivity.showConnectionInfo). -->
    <TextView
        android:id="@+id/connectionUrlText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="5dp"
        android:background="@drawable/bg_connect_chip"
        android:fontFamily="@font/space_grotesk_regular"
        android:textColor="@color/dash_text_muted"
        android:textSize="11sp"
        android:visibility="gone"
        tools:text="connect info"
        tools:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/wordmarkText"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Secondary quick-launch tiles: occasional-use actions, deliberately
         smaller and less visually dominant than the hero card above. -->
    <LinearLayout
        android:id="@+id/tilesColumn"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="@id/heroCard"
        app:layout_constraintBottom_toBottomOf="@id/heroCard"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.34">

        <include
            android:id="@+id/tileNavigation"
            layout="@layout/dash_tile"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <include
            android:id="@+id/tilePhone"
            layout="@layout/dash_tile"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="14dp" />

        <include
            android:id="@+id/tileMessages"
            layout="@layout/dash_tile"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="14dp" />
    </LinearLayout>

    <!-- Full-screen destination search (text field + live suggestions +
         CarKeyboardView), opened by NavigateMapFragment's "Where to?" pill.
         Lives here, not inside the hero card, so it gets the whole screen's
         height instead of just the hero card's fraction of it - see
         DestinationSearchOverlayView.kt. Drawn last = on top of everything. -->
    <app.vehplayer.android.dashboard.DestinationSearchOverlayView
        android:id="@+id/destinationSearchOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Same full-screen-overlay rationale as destinationSearchOverlay
         above, see MessagesOverlayView.kt. -->
    <app.vehplayer.android.dashboard.MessagesOverlayView
        android:id="@+id/messagesOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <app.vehplayer.android.dashboard.PhoneOverlayView
        android:id="@+id/phoneOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <app.vehplayer.android.dashboard.WidgetPickerOverlayView
        android:id="@+id/widgetPicker"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scan-to-probe QR (CarDashboardActivity.showProbeQr): tap the
         connection URL to open, tap anywhere to close. -->
    <FrameLayout
        android:id="@+id/probeQrOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#E6000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ScrollView so the card never clips on small/portrait screens
             (founder feedback, session 9: caption fell off the bottom);
             margins keep a dismiss-tappable border of the dimmed backdrop
             visible around the card on every screen size. -->
        <ScrollView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="24dp"
            android:background="@android:color/white">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="18dp">

                <!-- 200dp: 300dp + a multi-line caption overflows a landscape
                     phone screen (caption was clipped off the bottom, seen live
                     on the emulator, session 9). Still comfortably scannable. -->
                <ImageView
                    android:id="@+id/probeQrImage"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:contentDescription="Connection probe QR code" />

                <TextView
                    android:id="@+id/probeQrCaption"
                    android:layout_width="300dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/space_grotesk_regular"
                    android:textColor="#14120F"
                    android:textSize="12sp"
                    android:gravity="center" />
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <app.vehplayer.android.dashboard.NavAppPickerView
        android:id="@+id/navAppPicker"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
