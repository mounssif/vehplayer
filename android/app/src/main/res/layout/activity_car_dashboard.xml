<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dash_bg"
    android:padding="28dp">

    <TextView
        android:id="@+id/clockText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/space_grotesk_bold"
        android:textColor="@color/dash_text_primary"
        android:textSize="34sp"
        android:text="00:00"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/wordmarkText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/space_grotesk_medium"
        android:textColor="@color/dash_text_muted"
        android:textSize="15sp"
        android:letterSpacing="0.08"
        android:text="vehplayer"
        app:layout_constraintTop_toTopOf="@id/clockText"
        app:layout_constraintBottom_toBottomOf="@id/clockText"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Hero card: the single largest, most-glanced-at element, deliberately
         not a tile among equal tiles. Swipes between two pages (heroPager,
         adapter in CarDashboardActivity): Now Playing and Navigate - the
         "slide" the user asked for, each page a Fragment so the embedded
         MapView on the Navigate page gets correct lifecycle forwarding.
         clipToOutline rounds the pager's contents (incl. the edge-to-edge
         map) to bg_hero_card_shape's corner radius. -->
    <FrameLayout
        android:id="@+id/heroCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_hero_card_shape"
        android:clipToOutline="true"
        app:layout_constraintTop_toBottomOf="@id/clockText"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tilesColumn"
        app:layout_constraintWidth_percent="0.6"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="18dp">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/heroPager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:id="@+id/heroPageDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="14dp"
            android:orientation="horizontal"
            android:gravity="center">

            <View
                android:id="@+id/dotNowPlaying"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/dash_dot_active" />

            <View
                android:id="@+id/dotNavigate"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/dash_dot_inactive" />
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/connectionUrlText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:fontFamily="@font/space_grotesk_regular"
        android:textColor="@color/dash_text_muted"
        android:textSize="11sp"
        android:visibility="gone"
        tools:text="http://10.0.0.1:8080/go"
        tools:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/wordmarkText"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Secondary quick-launch tiles: occasional-use actions, deliberately
         smaller and less visually dominant than the hero card above. -->
    <LinearLayout
        android:id="@+id/tilesColumn"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="@id/heroCard"
        app:layout_constraintBottom_toBottomOf="@id/heroCard"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.34">

        <include
            android:id="@+id/tileNavigation"
            layout="@layout/dash_tile"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <include
            android:id="@+id/tilePhone"
            layout="@layout/dash_tile"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="14dp" />

        <include
            android:id="@+id/tileMessages"
            layout="@layout/dash_tile"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="14dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
